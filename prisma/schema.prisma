// Database Schema File.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// --------------  CUSTOMERS  ------------------  
model Customers {
  customerID  Int         @id @default(autoincrement())
  firstName   String      @db.VarChar(100)
  lastName    String      @db.VarChar(100)
  email       String?     @db.VarChar(100)
  phoneNumber String      @db.VarChar(20)
  invoices    Invoices[]

  @@map("Customers")
}

// --------------  EMPLOYEES  -------------------  
model Employees {
  employeeID Int         @id @default(autoincrement())
  firstName  String      @db.VarChar(100)
  lastName   String      @db.VarChar(100)
  hireDate   DateTime    @db.Date
  isActive   Int         @default(1) @db.SmallInt
  invoices   Invoices[] 

  @@map("Employees")
}

// --------------  INVOICES  -------------------  
model Invoices {
  invoiceID         Int                  @id @default(autoincrement())
  customerID        Int
  employeeID        Int
  invoiceDate       DateTime             @db.Date
  customers         Customers           @relation(fields: [customerID], references: [customerID], onDelete: Restrict)
  employees         Employees           @relation(fields: [employeeID], references: [employeeID], onDelete: Restrict) 
  invoiceSunglasses InvoiceSunglasses[]

  @@map("Invoices")
}

// ------------  SUNGLASSES  -------------------  
model Sunglasses {
  itemID            Int                  @id @default(autoincrement())
  itemName          String               @db.VarChar(100)
  retailPrice       Decimal              @default(0.00) @db.Decimal(5, 2)
  stockQuantity     Int
  isListed          Int                  @default(1) @db.SmallInt
  invoiceSunglasses InvoiceSunglasses[] 

  @@map("Sunglasses")
}

// ---------  INVOICESUNGLASSES  ---------------  
model InvoiceSunglasses {
  invoiceItemID Int         @id @default(autoincrement())
  invoiceID     Int
  itemID        Int
  quantity      Int
  invoices      Invoices   @relation(fields: [invoiceID], references: [invoiceID], onDelete: Cascade)
  sunglasses    Sunglasses @relation(fields: [itemID], references: [itemID], onDelete: Restrict) 

  @@unique([invoiceID, itemID], map: "unique_invoiceID_sunglassesID")
  @@map("InvoiceSunglasses")
}